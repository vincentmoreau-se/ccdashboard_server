# Ingest auth — shared bearer token distributed to all ccdashboard clients
# (set as CCDASH_EXPORT_TOKEN on the client side)
CCSRV_INGEST_TOKEN=change-me-shared-token

# Dashboard login (single shared password) + cookie signing secret
CCSRV_DASHBOARD_PASSWORD=change-me
CCSRV_SECRET_KEY=please-generate-a-long-random-string

# Reference data + storage
CCSRV_PARTICIPANTS_CSV=./participants.csv
CCSRV_DB_PATH=./ccsrv.db

# Liveness / live-rate tuning
CCSRV_LIVE_WINDOW_SECONDS=120
CCSRV_SNAPSHOT_INTERVAL_SECONDS=60

# Presentation
CCSRV_CURRENCY=€
CCSRV_EVENT_NAME=Hackathon

# LiteLLM source (optional) — fills in participants not covered by the ccdashboard
# client by polling the LiteLLM proxy. Disabled by default.
CCSRV_LITELLM_ENABLED=false
CCSRV_LITELLM_BASE_URL=http://litellm:4000
CCSRV_LITELLM_MASTER_KEY=
CCSRV_LITELLM_POLL_INTERVAL_SECONDS=300
CCSRV_LITELLM_LOOKBACK_DAYS=2

# Production only: serve cookie over HTTPS
CCSRV_COOKIE_SECURE=false

# CORS origin of the frontend dev server
CCSRV_FRONTEND_ORIGIN=http://localhost:5173

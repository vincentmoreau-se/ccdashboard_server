# Production env template for the Docker deployment.
# Copy to `.env` next to docker-compose.yml on the server and fill in secrets.
# This file is a template — never commit the real `.env` (it is gitignored).

# Ingest auth — shared bearer token distributed to ccdashboard clients
CCSRV_INGEST_TOKEN=change-me-shared-token

# Dashboard login (single shared password) + cookie signing secret
CCSRV_DASHBOARD_PASSWORD=change-me
CCSRV_SECRET_KEY=please-generate-a-long-random-string   # openssl rand -hex 32

# Served behind an HTTPS reverse proxy
CCSRV_COOKIE_SECURE=true
CCSRV_FRONTEND_ORIGIN=https://your-domain.example

# Storage (db lives in the mounted ./data volume; csv is mounted read-only)
CCSRV_DB_PATH=/data/ccsrv.db
CCSRV_PARTICIPANTS_CSV=/app/participants.csv
CCSRV_FRONTEND_DIST=/app/frontend/dist

# Liveness / live-rate tuning
CCSRV_LIVE_WINDOW_SECONDS=120
CCSRV_SNAPSHOT_INTERVAL_SECONDS=60

# Presentation
CCSRV_CURRENCY=€
CCSRV_EVENT_NAME=Hackathon
# Stored costs are USD (Anthropic list prices / LiteLLM spend). Multiply by this
# rate at display time so the "€" label is truthful (approx. fixed rate).
CCSRV_USD_EUR_RATE=0.92

# LiteLLM source (optional) — fills in participants not covered by the ccdashboard
# client. Reaches the proxy over the shared `msf` Docker network; no port publish.
CCSRV_LITELLM_ENABLED=true
CCSRV_LITELLM_BASE_URL=http://litellm:4000
CCSRV_LITELLM_MASTER_KEY=change-me-litellm-master-key
CCSRV_LITELLM_POLL_INTERVAL_SECONDS=300
CCSRV_LITELLM_LOOKBACK_DAYS=2
